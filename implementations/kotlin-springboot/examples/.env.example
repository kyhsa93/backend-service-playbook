# Used when running the app directly locally via ./gradlew bootRun.
# Copy this file to create .env.development — .env.development is not committed.
# Spring Boot doesn't automatically read .env files, so load it into the shell via direnv
# or similar, or run it like `export $(cat .env.development | xargs) && ./gradlew bootRun`.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=dev

AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SES_SENDER_EMAIL=no-reply@backend-service-playbook.example.com
SQS_DOMAIN_EVENT_QUEUE_URL=http://localhost:4566/000000000000/domain-events
SQS_TASK_QUEUE_URL=http://localhost:4566/000000000000/task-queue.fifo

# jjwt (HS256) requires a key of at least 256 bits (32 bytes).
JWT_SECRET=local-dev-secret-local-dev-secret

# Refund reason classification (see payment/infrastructure/RefundReasonClassifierImpl.kt) — served
# locally by Ollama (docker-compose.yml). No API key: it's a self-hosted open-source model.
OLLAMA_BASE_URL=http://localhost:11434
REFUND_CLASSIFIER_MODEL=qwen2.5:1.5b

# Refund fraud-risk scoring (see payment/application/service/RefundFraudRiskScorer.kt) — 'native'
# (default) trains a small model in-process at startup, no extra service needed. Set to 'http' to
# call the shared services/fraud-risk-scorer microservice (docker-compose.yml) instead.
FRAUD_SCORER_MODE=native
FRAUD_SCORER_BASE_URL=http://localhost:8000

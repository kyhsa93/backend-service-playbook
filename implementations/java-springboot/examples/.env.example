# Used when running the app directly locally via ./gradlew bootRun.
# Copy this file to .env.development — do not commit .env.development.
# Spring Boot does not automatically read .env files, so load it into the shell via direnv, etc.,
# or run it like `export $(cat .env.development | xargs) && ./gradlew bootRun`.

SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app
SPRING_DATASOURCE_USERNAME=dev
SPRING_DATASOURCE_PASSWORD=dev

AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
SES_SENDER_EMAIL=no-reply@backend-service-playbook.example.com
SQS_DOMAIN_EVENT_QUEUE_URL=http://localhost:4566/000000000000/domain-events
SQS_TASK_QUEUE_URL=http://localhost:4566/000000000000/task-queue.fifo

JWT_SECRET=local-dev-secret-local-dev-secret

# Refund reason classification (see payment/infrastructure/RefundReasonClassifierImpl.java)
ANTHROPIC_API_KEY=
REFUND_CLASSIFIER_MODEL=claude-opus-4-8
